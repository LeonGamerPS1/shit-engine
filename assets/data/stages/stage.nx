func onStageLoad(s,s) {
    var bg = new FunkinSprite(-600,-200)
    bg.loadImage("stages/stage/stageback")
    bg.scrollFactor.set(0.9,0.9)
    bg.scale.set(2,2)
    bg.updateHitbox()
    bg.active = false
    bg.antialiasing = true
    game.add(bg)

    var bgFront = new FunkinSprite(-650,600)
    bgFront.loadImage("stages/stage/stagefront")
    bgFront.scale.set(0.9 * 2,0.9 * 2)
    bgFront.active = false 
    bgFront.updateHitbox()
    bgFront.antialiasing = true
    game.add(bgFront)
}

